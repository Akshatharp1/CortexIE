# CortexIE — environment configuration
# Copy this file to .env and fill in the values for your chosen provider.
# The server reads these on startup via process.env.

# ─── Provider selection ────────────────────────────────────────────────────────
# Choose the backend driver for sandbox provisioning.
#   local    (default) — Node child processes on this machine.  No extra setup.
#   docker             — Docker containers.  Requires Docker Desktop / Engine.
#   rancher            — Kubernetes via Rancher API.  Requires cluster access.
CORTEXIE_PROVIDER=local

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000

# ─── Docker provider (CORTEXIE_PROVIDER=docker) ───────────────────────────────
# Registry prefix for service images.
# Image name pattern: <DOCKER_REGISTRY>/<service-name>:latest
# Example: myregistry.io/cortexie/leasestar-web:latest
DOCKER_REGISTRY=myregistry.io/cortexie

# Bridge network to attach all sandbox containers to.
# Create it once: docker network create cortexie
DOCKER_NETWORK=cortexie

# Internal port that service images listen on (the container side of -p).
DOCKER_CONTAINER_PORT=8080

# ─── Rancher / Kubernetes provider (CORTEXIE_PROVIDER=rancher) ────────────────
# Full URL of your Rancher server.
RANCHER_URL=https://rancher.internal

# Rancher API token.  Create via: Rancher UI → Avatar → Account & API Keys → Add Key
# Format: token-xxxxx:xxxxxxxxxxxxxxxxxx
RANCHER_TOKEN=token-xxxxx:xxxxxxxxxxxxxxxxxx

# Target downstream cluster ID.
# Find it: GET <RANCHER_URL>/v3/clusters  →  copy the `id` field  (e.g. c-m-abcd1234)
RANCHER_CLUSTER_ID=c-m-abcd1234

# Project ID that namespaces will be created under.
# Find it: GET <RANCHER_URL>/v3/clusters/<CLUSTER_ID>/projects  →  copy `id`
# Format: <clusterId>:<projectShortId>  e.g. c-m-abcd1234:p-xxxxx
RANCHER_PROJECT_ID=c-m-abcd1234:p-xxxxx

# Prefix for Kubernetes namespaces created by CortexIE.
# Each environment gets a namespace named: <prefix><envId>
RANCHER_NAMESPACE_PREFIX=cortexie-

# Container image registry for Rancher-provisioned workloads.
# Image name pattern: <RANCHER_IMAGE_REGISTRY>/<service-name>:latest
RANCHER_IMAGE_REGISTRY=myregistry.io/cortexie

# Set to true if Rancher uses a self-signed TLS certificate (common on internal clusters).
RANCHER_SKIP_TLS=false

# ─── AI planning engine (frontend, optional) ──────────────────────────────────
# Only needed if you switch the AI toggle to "Claude API" in the Settings page.
# The key is stored in-memory in the browser — use a backend proxy in production.
# ANTHROPIC_API_KEY=sk-ant-...
